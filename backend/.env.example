# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/project_management_system?schema=public

# Optional folder scan root path used by the backend
SCAN_ROOT_PATH=C:\Users\your-user\Documents\Leed Project

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d

# API Configuration
API_BASE_URL=http://localhost:5000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# System email notification SMTP setup
# Use ONE system SMTP account. Manager email is passed as Reply-To from the calendar popup.
# For Gmail, use an app password, port 465, and SMTP_SECURE=true.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_CLIENT_NAME=localhost

