# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/project_management_system?schema=public

# Optional folder scan root path used by the backend
SCAN_ROOT_PATH=C:\Users\your-user\Documents\Leed Project

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d

# API Configuration
API_BASE_URL=http://localhost:5000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Resend email setup
# Create an API key at https://resend.com/api-keys.
# RESEND_FROM must use a sender/domain verified in your Resend account.
RESEND_API_KEY=
RESEND_FROM=
OWNER_EMAIL=monikaswami2614@gmail.com

